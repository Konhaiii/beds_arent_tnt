{
	"schemaVersion": 1,
	"id": "beds_arent_tnt",
	"version": "${version}",
	"name": "Beds Aren't TNT",
	"description": "Using a bed in the Nether or the End no longer causes an explosion.",
	"authors": [
		"Konhaiii"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC BY-NC 4.0",
	"icon": "assets/beds_arent_tnt/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"konhaiii.beds_arent_tnt.BedsArentTNT"
		],
		"client": [
			"konhaiii.beds_arent_tnt.BedsArentTNTClient"
		]
	},
	"mixins": [
		"beds_arent_tnt.mixins.json",
		{
			"config": "beds_arent_tnt.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.5",
		"minecraft": "~26.1",
		"java": ">=25",
		"fabric-api": "*"
